{
  "version": 2,
  "rewrites": [
    { 
      "source": "/(.*)", 
      "destination": "/index.html",
      "has": [
        { "type": "header", "key": "x-not-a-static-file" }
      ]
    },
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "routes": [
    { "src": "/styles.css", "dest": "/styles.css" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
